# ==========================================
# ARANCEL HONDURAS BOT — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# ==========================================

# TOKEN del bot obtenido de @BotFather en Telegram
BOT_TOKEN=123456789:ABCDefgh-tuTokenAquí

# Tu ID de Telegram como administrador (usa /myid para obtenerlo)
ADMIN_ID=123456789

# URL de PostgreSQL — Railway la genera automáticamente
DATABASE_URL=postgresql://usuario:contraseña@host:puerto/basededatos

# SOLO para producción en Railway (dejar en blanco en desarrollo)
# URL pública de Railway, ej: https://arancel-bot-production.up.railway.app
WEBHOOK_URL=

# Ambiente: "production" en Railway, vacío o "development" en local
NODE_ENV=development

# Puerto (Railway lo asigna automáticamente, no cambiar)
PORT=3000
